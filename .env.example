# Telegram API from my.telegram.org
API_ID=123456
API_HASH=your_api_hash

# Comma-separated chat usernames or IDs, e.g. @chat1,@chat2 or -100123,...
TG_SOURCE_CHATS=@public_chat_username

# Queue
AMQP_URL=amqps://user:pass@host/vhost
AMQP_QUEUE_LEADS=leads_candidates

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_or_anon_key

# OpenRouter / OpenAI-compatible API
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=openai/gpt-4o-mini

# Notification webhook (Cloudflare Worker endpoint)
NOTIFIER_WEBHOOK_URL=https://example.workers.dev/notify
